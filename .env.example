# ─────────────────────────────────────────────────────────────
# XFlight — environment template
# Copy to .env.local and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── X Layer ──
XLAYER_CHAIN_ID=196
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_EXPLORER_URL=https://www.oklink.com/xlayer

# ── XFlight Agentic Wallet ──
# Private key for the autonomous signer that attests reports on X Layer.
# Generate: node -e "const { ethers } = require('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
# Fund the derived address with a small amount of OKB before running attestations.
ATTESTER_PRIVATE_KEY=0x...

# ── XFlightRecorder contract ──
# Populated automatically after `npm run deploy`.
XFLIGHT_CONTRACT_ADDRESS=0x...

# ── DGrid AI Gateway (GPT-4o via decentralized inference) ──
# Used for AI claim extraction + analysis. Regex fallback runs without a key.
DGRID_API_KEY=sk-...

# ── OnchainOS / OKX DEX + Wallet APIs ──
# Optional — when set, /api/quote and /api/portfolio call the live OKX DEX
# Aggregator and Wallet Portfolio APIs (HMAC-signed). Without these, XFlight
# falls back to Uniswap V3 QuoterV2 and native-balance RPC reads.
# Get credentials: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
